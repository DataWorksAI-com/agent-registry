# Copy to .env and fill in values before deploying
# See DANS.md for full documentation

# ── DANS server ────────────────────────────────────────────────────────────────
# URN namespace issued by this instance (shows up in registered agent URNs)
AGENTNS_TLD=agents.dataworksai.com
AGENTNS_NAMESPACE=public

# MongoDB Atlas (optional — uses in-memory store if not set)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_DB=ans_public

# Auth — "off" = open mode (default), "on" = require X-API-Key on writes
# Set to "on" for public deployments; requires MONGODB_URI
DANS_AUTH=off

# Fallback registry (optional) — resolve agents registered in a separate registry
# ANS_FALLBACK_URL=http://your-registry:6900

# ── Client SDK ─────────────────────────────────────────────────────────────────
# Used by agentns.requester_lib.connect() and agentns.target_lib.connect()
AGENTNS_URL=http://localhost:8200
AGENTNS_API_KEY=
