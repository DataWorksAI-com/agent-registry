# Copy to .env and fill in values before deploying

# ── Registry ───────────────────────────────────────────────────────────────────
SAAS_MODE=1
ENABLE_FEDERATION=true
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB=agent_registry

# Shared secret between control plane and registry (generate with: openssl rand -hex 32)
CONTROL_PLANE_SECRET=change-me

# ANS settings (optional)
ANS_APP=default
AUTH_NS_URL=

# ── agentns sidecar ────────────────────────────────────────────────────────────
AGENTNS_TLD=agentns.io
AGENTNS_AUTH=off

# ── Control plane ──────────────────────────────────────────────────────────────
SECRET_KEY=change-me
REGISTRY_URL=http://registry:6900
